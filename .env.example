# SOCKS5 代理地址 (留空则不使用代理)
# 示例: socks5://127.0.0.1:1080
PROXY_URL=socks5://127.0.0.1:1080

# EulerStream API Key (获取: https://www.eulerstream.com)
EULER_API_KEY=

# 可选: TikTok Session ID (登录后的Cookie)
SESSIONID=

# 服务端口
PORT=8081

# ========== 方案A / Feature Flags ==========

# 开启方案A结构化日志与关键指标（默认关闭；关闭时不影响现有业务结果）
ENABLE_SCHEME_A_OBSERVABILITY=false

# Redis（Phase 2，默认关闭）
REDIS_URL=redis://127.0.0.1:6379/0
ENABLE_REDIS_ROOM_CACHE=false
ENABLE_REDIS_LIVE_STATE=false

# Worker（Phase 1 / Phase 3，默认关闭）
ENABLE_RECORDING_UPLOAD=false
ENABLE_RECORDING_UPLOAD_DAEMON=false
RECORDING_UPLOAD_WORKER_POLL_MS=10000
RECORDING_UPLOAD_WORKER_BATCH_SIZE=5
RECORDING_UPLOAD_DAEMON_RESTART_DELAY_MS=5000
RECORDING_UPLOAD_DAEMON_MAX_RESTARTS=0
ENABLE_RECORDING_LOCAL_CLEANUP=false
RECORDING_LOCAL_CLEANUP_DELAY_MS=3600000
RECORDING_LOCAL_CLEANUP_BATCH_SIZE=10
ENABLE_WORKER_STATS=false
ENABLE_WORKER_MAINTENANCE=false

# 录播下载 accessToken（建议显式配置；未配置时服务会生成进程内临时密钥，重启后旧链接失效）
RECORDING_ACCESS_TOKEN_SECRET=
RECORDING_ACCESS_TOKEN_TTL_SECS=900

# 对象存储（Phase 1，默认留空）
OBJECT_STORAGE_PROVIDER=s3
OSS_ENDPOINT=
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PUBLIC_BASE_URL=
OSS_SIGNED_URL_TTL_SECS=900

# 事件分区 / 增量汇总（后续阶段，默认关闭）
EVENT_PARTITION_WRITE_MODE=disabled
ENABLE_INCREMENTAL_STATS=false

# ========== 动态代理配置 (二选一) ==========

# 方式1: 隧道代理 (推荐)
# 格式: http://用户名:密码@主机:端口
# 示例: http://v1_123456-dh-2-region-hk:password@hk.ipdodo.cloud:10801
DYNAMIC_TUNNEL_PROXY=

# 方式2: 代理池API
# 格式: 返回 ip:port 列表的API地址
# 示例: http://api.provider.com/get?num=10&format=text
PROXY_API_URL=
